{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaInvokeFunctions",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction"
      ],
      "Resource": [
        "arn:aws:lambda:ap-northeast-2:*:function:hezo-p4-upload-contract",
        "arn:aws:lambda:ap-northeast-2:*:function:hezo-p4-upload-contract:*"
      ]
    },
    {
      "Sid": "DynamoDBPipelineState",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-northeast-2:*:table/hezo_pipeline_state"
      ]
    },
    {
      "Sid": "BedrockInvokeAgent",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeAgent"
      ],
      "Resource": [
        "arn:aws:bedrock:ap-northeast-2:*:agent/*",
        "arn:aws:bedrock:ap-northeast-2:*:agent-alias/*"
      ]
    },
    {
      "Sid": "ECSRunTask",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask",
        "ecs:DescribeTasks",
        "ecs:StopTask"
      ],
      "Resource": [
        "arn:aws:ecs:ap-northeast-2:*:task-definition/hezo-*",
        "arn:aws:ecs:ap-northeast-2:*:task/*"
      ]
    },
    {
      "Sid": "ECSClusterAccess",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTaskDefinition",
        "ecs:ListTasks"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IAMPassRoleForECS",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": [
        "arn:aws:iam::*:role/hezo-lambda-execution-role",
        "arn:aws:iam::*:role/hezo-ecs-task-role",
        "arn:aws:iam::*:role/hezo-ecs-execution-role"
      ],
      "Condition": {
        "StringLike": {
          "iam:PassedToService": [
            "ecs-tasks.amazonaws.com",
            "lambda.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "CloudWatchLogsForStepFunctions",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogDelivery",
        "logs:CreateLogStream",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams",
        "logs:DescribeResourcePolicies",
        "logs:GetLogDelivery",
        "logs:ListLogDeliveries",
        "logs:PutLogEvents",
        "logs:PutResourcePolicy",
        "logs:UpdateLogDelivery"
      ],
      "Resource": [
        "arn:aws:logs:ap-northeast-2:*:log-group:/hezo/step-functions/*",
        "arn:aws:logs:ap-northeast-2:*:log-group:/aws/states/*"
      ]
    },
    {
      "Sid": "CloudWatchMetrics",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    },
    {
      "Sid": "XRayAccess",
      "Effect": "Allow",
      "Action": [
        "xray:PutTraceSegments",
        "xray:PutTelemetryRecords",
        "xray:GetSamplingRules",
        "xray:GetSamplingTargets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SNSPublishForNotifications",
      "Effect": "Allow",
      "Action": [
        "sns:Publish"
      ],
      "Resource": [
        "arn:aws:sns:ap-northeast-2:*:hezo-*"
      ]
    }
  ]
}
