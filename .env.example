# ============================================================
# HEZO-Agent 배포 환경 변수 템플릿
# 실제 값은 .env 파일에 작성 (git에 커밋하지 않음)
# ============================================================

# ── AWS 기본 설정 ──────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-northeast-2
AWS_PROFILE=your-aws-profile          # ~/.aws/config에 정의된 프로파일명

# ── S3 버킷 ────────────────────────────────────────────────
ARTIFACTS_BUCKET=hezo-artifacts       # contract_final.json, render_spec.json 저장
SITES_BUCKET=hezo-sites               # 빌드된 정적 사이트 저장

# ── DynamoDB ───────────────────────────────────────────────
PIPELINE_STATE_TABLE=hezo_pipeline_state

# ── Step Functions (aws_setup.sh 또는 deploy_state_machine.sh 실행 후 채움) ──
STEP_FUNCTIONS_ARN=

# ── Bedrock Agent (deploy.sh 실행 후 채움) ─────────────────
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
