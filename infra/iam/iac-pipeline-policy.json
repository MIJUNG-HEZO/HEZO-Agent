{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudFormation",
      "Effect": "Allow",
      "Action": ["cloudformation:CreateStack","cloudformation:UpdateStack","cloudformation:DescribeStacks","cloudformation:DeleteStack"],
      "Resource": "arn:aws:cloudformation:ap-northeast-2:492554570964:stack/hezo-customer-*/*"
    },
    {
      "Sid": "StackResources",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "cloudfront:*",
        "route53:*",
        "iam:CreateRole","iam:DeleteRole","iam:AttachRolePolicy","iam:DetachRolePolicy",
        "iam:PutRolePolicy","iam:DeleteRolePolicy","iam:GetRole","iam:PassRole",
        "iam:CreateInstanceProfile","iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile","iam:RemoveRoleFromInstanceProfile",
        "iam:TagRole","iam:ListRolePolicies","iam:GetRolePolicy"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PostStack",
      "Effect": "Allow",
      "Action": ["cloudfront:CreateInvalidation","scheduler:CreateSchedule","dynamodb:UpdateItem","dynamodb:PutItem"],
      "Resource": "*"
    },
    {
      "Sid": "FailAlert",
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "*"
    }
  ]
}
