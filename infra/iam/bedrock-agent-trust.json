{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockAgentAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "${AWS_ACCOUNT_ID}"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:bedrock:ap-northeast-2:${AWS_ACCOUNT_ID}:agent/*"
        }
      }
    }
  ]
}
