{
  "Comment": "HEZO Site Generation Pipeline v3.0 — CheckIdempotency → Generation → Build(ECS) → Validation → Publish",
  "StartAt": "CheckIdempotency",
  "States": {

    "CheckIdempotency": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:getItem",
      "Parameters": {
        "TableName": "pipeline_state",
        "Key": {
          "site_id": { "S.$": "$.site_id" }
        },
        "ProjectionExpression": "publish_status"
      },
      "ResultPath": "$.idempotency",
      "Next": "IsAlreadyPublished",
      "Retry": [
        {
          "ErrorEquals": ["DynamoDB.DynamoDbException", "DynamoDB.ProvisionedThroughputExceededException"],
          "IntervalSeconds": 2,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkFailed",
          "ResultPath": "$.error"
        }
      ]
    },

    "IsAlreadyPublished": {
      "Type": "Choice",
      "Choices": [
        {
          "And": [
            {
              "Variable": "$.idempotency.Item.publish_status.S",
              "IsPresent": true
            },
            {
              "Variable": "$.idempotency.Item.publish_status.S",
              "StringEquals": "published"
            }
          ],
          "Next": "AlreadyPublished"
        }
      ],
      "Default": "MarkBuilding"
    },

    "AlreadyPublished": {
      "Type": "Succeed"
    },

    "MarkBuilding": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:updateItem",
      "Parameters": {
        "TableName": "pipeline_state",
        "Key": {
          "site_id": { "S.$": "$.site_id" }
        },
        "UpdateExpression": "SET publish_status = :building",
        "ConditionExpression": "attribute_not_exists(publish_status) OR publish_status <> :published",
        "ExpressionAttributeValues": {
          ":building": { "S": "building" },
          ":published": { "S": "published" }
        }
      },
      "ResultPath": null,
      "Next": "InvokeGenerationAgent",
      "Catch": [
        {
          "ErrorEquals": ["DynamoDB.ConditionalCheckFailedException"],
          "Next": "AlreadyPublished",
          "ResultPath": null
        },
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkFailed",
          "ResultPath": "$.error"
        }
      ]
    },

    "InvokeGenerationAgent": {
      "Type": "Task",
      "Resource": "arn:aws:states:::http:invoke",
      "Parameters": {
        "ApiEndpoint": "${GENERATION_AGENT_ENDPOINT}/invocations",
        "Method": "POST",
        "Headers": {
          "Content-Type": "application/json"
        },
        "RequestBody": {
          "site_id.$": "$.site_id",
          "pipeline_run_id.$": "$$.Execution.Name"
        },
        "Authentication": {
          "ConnectionArn": "${EVENTBRIDGE_CONNECTION_ARN}"
        }
      },
      "ResultPath": "$.generation_result",
      "Next": "InvokeBuildWorker",
      "TimeoutSeconds": 300,
      "Retry": [
        {
          "ErrorEquals": ["States.Http.StatusCode429", "States.Http.StatusCode503", "States.Timeout"],
          "IntervalSeconds": 15,
          "MaxAttempts": 2,
          "BackoffRate": 2,
          "JitterStrategy": "FULL"
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkFailed",
          "ResultPath": "$.error"
        }
      ]
    },

    "InvokeBuildWorker": {
      "Type": "Task",
      "Resource": "arn:aws:states:::ecs:runTask.sync",
      "Parameters": {
        "Cluster": "${ECS_CLUSTER}",
        "TaskDefinition": "hezo-build-worker",
        "LaunchType": "FARGATE",
        "Overrides": {
          "ContainerOverrides": [
            {
              "Name": "build-worker",
              "Environment": [
                { "Name": "SITE_ID", "Value.$": "$.site_id" },
                { "Name": "MODE", "Value": "publish" }
              ]
            }
          ]
        },
        "NetworkConfiguration": {
          "AwsvpcConfiguration": {
            "Subnets": ["${ECS_SUBNET_1}", "${ECS_SUBNET_2}"],
            "SecurityGroups": ["${ECS_SECURITY_GROUP}"],
            "AssignPublicIp": "DISABLED"
          }
        }
      },
      "ResultPath": "$.build_result",
      "Next": "MarkValidating",
      "TimeoutSeconds": 600,
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed", "ECS.EcsException"],
          "IntervalSeconds": 15,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkFailed",
          "ResultPath": "$.error"
        }
      ]
    },

    "MarkValidating": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:updateItem",
      "Parameters": {
        "TableName": "pipeline_state",
        "Key": {
          "site_id": { "S.$": "$.site_id" }
        },
        "UpdateExpression": "SET publish_status = :validating",
        "ExpressionAttributeValues": {
          ":validating": { "S": "validating" }
        }
      },
      "ResultPath": null,
      "Next": "InvokeValidationAgent"
    },

    "InvokeValidationAgent": {
      "Type": "Task",
      "Resource": "arn:aws:states:::http:invoke",
      "Parameters": {
        "ApiEndpoint": "${VALIDATION_AGENT_ENDPOINT}/invocations",
        "Method": "POST",
        "Headers": {
          "Content-Type": "application/json"
        },
        "RequestBody": {
          "site_id.$": "$.site_id",
          "pipeline_run_id.$": "$$.Execution.Name"
        },
        "Authentication": {
          "ConnectionArn": "${EVENTBRIDGE_CONNECTION_ARN}"
        }
      },
      "ResultPath": "$.validation_result",
      "Next": "CheckValidationResult",
      "TimeoutSeconds": 1800,
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkFailed",
          "ResultPath": "$.error"
        }
      ]
    },

    "CheckValidationResult": {
      "Type": "Choice",
      "Choices": [
        {
          "Or": [
            {
              "Variable": "$.validation_result.ResponseBody.validation_status",
              "StringEquals": "PASS"
            },
            {
              "Variable": "$.validation_result.ResponseBody.validation_status",
              "StringEquals": "PASS_WITH_WARNINGS"
            }
          ],
          "Next": "MarkPublished"
        },
        {
          "Variable": "$.validation_result.ResponseBody.validation_status",
          "StringEquals": "FAIL_BLOCKING",
          "Next": "MarkFailed"
        }
      ],
      "Default": "MarkFailed"
    },

    "MarkPublished": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:updateItem",
      "Parameters": {
        "TableName": "pipeline_state",
        "Key": {
          "site_id": { "S.$": "$.site_id" }
        },
        "UpdateExpression": "SET publish_status = :published",
        "ExpressionAttributeValues": {
          ":published": { "S": "published" }
        }
      },
      "ResultPath": null,
      "Next": "PublishSiteEvent"
    },

    "PublishSiteEvent": {
      "Type": "Task",
      "Resource": "arn:aws:states:::events:putEvents",
      "Parameters": {
        "Entries": [
          {
            "EventBusName": "default",
            "Source": "hezo.pipeline",
            "DetailType": "site-published",
            "Detail": {
              "site_id.$": "$.site_id",
              "execution_name.$": "$$.Execution.Name",
              "ai_score.$": "$.validation_result.ResponseBody.ai_score"
            }
          }
        ]
      },
      "ResultPath": null,
      "Next": "PipelineSuccess"
    },

    "PipelineSuccess": {
      "Type": "Succeed"
    },

    "MarkFailed": {
      "Type": "Task",
      "Resource": "arn:aws:states:::dynamodb:updateItem",
      "Parameters": {
        "TableName": "pipeline_state",
        "Key": {
          "site_id": { "S.$": "$.site_id" }
        },
        "UpdateExpression": "SET publish_status = :failed",
        "ExpressionAttributeValues": {
          ":failed": { "S": "failed" }
        }
      },
      "ResultPath": null,
      "Next": "HandleFailure",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "PipelineFailed",
          "ResultPath": null
        }
      ]
    },

    "HandleFailure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-northeast-2:${AWS_ACCOUNT_ID}:hezo-pipeline-alerts",
        "Subject": "HEZO Pipeline Failed",
        "Message.$": "States.Format('Pipeline failed for site_id={}, execution={}', $.site_id, $$.Execution.Name)"
      },
      "ResultPath": null,
      "Next": "PipelineFailed",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "PipelineFailed",
          "ResultPath": null
        }
      ]
    },

    "PipelineFailed": {
      "Type": "Fail",
      "Error": "PipelineFailed",
      "Cause": "Site generation pipeline failed. Check SNS alert and CloudWatch Logs."
    }

  }
}
